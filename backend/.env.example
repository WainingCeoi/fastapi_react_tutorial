# Backend settings — read by app/config.py (pydantic-settings).
# Copy to backend/.env and fill SECRET_KEY. The app fails fast at startup if it's missing.

# SQLite database file (any SQLAlchemy URL works).
DATABASE_URL=sqlite:///database.db

# Signs the JWT login tokens. REQUIRED, must be 32+ chars — generate one with:
#   openssl rand -hex 32
# This is THE secret to set before hosting on a LAN (`make host`). Keep it stable, or
# already-issued tokens stop verifying. There is no public base URL to configure: the built
# UI calls the API at a relative /api, so it works on localhost, <machine>.local, or a LAN IP
# with no rebuild.
SECRET_KEY=

# --- Optional (safe defaults in code; uncomment only to override) ---
# CORS allow-list for the SEPARATE dev frontend. Used only by `make dev` (cross-origin).
# `make start` / `make host` serve the UI same-origin, so LAN hosting needs nothing here.
#FRONTEND_ORIGIN=http://localhost:5173
